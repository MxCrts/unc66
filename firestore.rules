rules_version = '2';

// Règle commune à toutes les collections du site : contenu public en lecture
// (le site vitrine n'a pas de notion de visiteur connecté), écriture réservée
// aux utilisateurs authentifiés (le compte admin UNC 66 créé dans Firebase Auth).
// Pas de rôle "admin" distinct pour l'instant : un seul compte existe, donc
// "authentifié" == "admin". À affiner avec des custom claims si plusieurs
// comptes avec des droits différents sont créés un jour.
service cloud.firestore {
  match /databases/{database}/documents {

    match /actualites/{id} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /agenda/{id} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /motDuPresident/{id} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /documents/{id} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Tout le reste est fermé par défaut (pas de règle = pas d'accès).
  }
}
