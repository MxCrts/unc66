# Configuration Firebase du projet UNC 66.
# Copier ce fichier en ".env" (non versionné) et remplir avec les vraies valeurs
# depuis la console Firebase : https://console.firebase.google.com
# Projet > Paramètres du projet > Vos applications > Config SDK

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
